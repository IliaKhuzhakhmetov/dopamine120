<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools"
  package="com.dopamine120.platform_bridge">

  <!-- Required to evaluate foreground-app usage for blocking. Granted by the
       user via Settings > Special access > Usage access. -->
  <uses-permission
    android:name="android.permission.PACKAGE_USAGE_STATS"
    tools:ignore="ProtectedPermissions" />

  <!-- Health Connect read permissions for the metrics the bridge supports. -->
  <uses-permission android:name="android.permission.health.READ_SLEEP" />
  <uses-permission android:name="android.permission.health.READ_RESTING_HEART_RATE" />
  <uses-permission android:name="android.permission.health.READ_HEART_RATE_VARIABILITY" />
  <uses-permission android:name="android.permission.health.READ_STEPS" />

  <!-- Package visibility (Android 11+): needed so pickApps() can see
       launchable apps and detect the Health Connect provider. -->
  <queries>
    <intent>
      <action android:name="android.intent.action.MAIN" />
      <category android:name="android.intent.category.LAUNCHER" />
    </intent>
    <package android:name="com.google.android.apps.healthdata" />
  </queries>

  <application>
    <!-- Minimal blocking stub: sends a blocked app's task to the background
         when it reaches the foreground. The user must enable this service
         manually under Settings > Accessibility. -->
    <service
      android:name=".AppBlockerService"
      android:exported="false"
      android:label="DOPAMINE120 app blocker"
      android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
      <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
      </intent-filter>
      <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/app_blocker_service_config" />
    </service>
  </application>
</manifest>
