{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DOPAMINE120",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/dopamine120",
      "program": "lib/main.dart"
    },
    {
      "name": "DOPAMINE120 (profile)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/dopamine120",
      "program": "lib/main.dart",
      "flutterMode": "profile"
    },
    {
      "name": "UI Kit Widgetbook (macOS)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/packages/dopamine_ui/example",
      "program": "lib/main.dart",
      "deviceId": "macos"
    },
    {
      "name": "UI Kit Widgetbook (Chrome)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/packages/dopamine_ui/example",
      "program": "lib/main.dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--web-hostname=127.0.0.1",
        "--web-port=62011"
      ]
    }
  ]
}
